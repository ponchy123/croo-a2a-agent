# CROO SDK Configuration
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Agent API Keys (get from https://agent.croo.network)
# Requester Agent - for making requests to other agents
REQUESTER_API_KEY=croo_sk_requester_key_here
# Provider Agent - for providing services to other agents
PROVIDER_API_KEY=croo_sk_provider_key_here

# Default API Key (used by provider.ts)
CROO_SDK_KEY=croo_sk_default_key_here

# Target Service ID (from Agent Store configuration)
PROVIDER_SERVICE_ID=your_service_id_here

# Optional: Third-party API Keys (for enhanced translation)
OPENAI_API_KEY=your_openai_key_here
DEEPL_API_KEY=your_deepl_key_here